---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  showBackLink?: boolean;
}

const { 
  title, 
  description = "Mingz — UX Designer & Researcher portfolio", 
  showBackLink = false 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Google+Sans+Flex:wght@100..900&family=National+Park:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <title>{title}</title>
  <script>
    import 'iconify-icon';
    import { addCollection } from 'iconify-icon';
    import tablerIcons from '@iconify-json/tabler/icons.json';
    addCollection(tablerIcons);
  </script>
</head>
<body class="bg-cream text-ink font-sans min-h-screen">
  <div class="max-w-[860px] mx-auto px-6">
    {showBackLink && (
      <a href="/" class="inline-flex items-center gap-1.5 text-sm text-ink-muted hover:text-vermillion transition-colors duration-150 pt-8 group">
        <span class="transition-transform group-hover:-translate-x-1">←</span> Back to home
      </a>
    )}
    
    <main>
      <slot />
    </main>

    <footer class="border-t border-border-custom py-7 text-xs text-ink-muted flex justify-between items-center flex-wrap gap-2 mt-auto">
      <span>Mingz &copy; 2026</span>
      <a href="mailto:mingrui.lee@gmail.com" class="text-vermillion hover:underline">mingrui.lee@gmail.com</a>
    </footer>
  </div>
</body>
</html>
