---
import Layout from '../layouts/Layout.astro';
---

<style>
  .card-brain:hover  { border-color: #FF6B4A; box-shadow: 0 0 0 0.5px #FF6B4A; }
  .card-bulb:hover   { border-color: #FFBE26; box-shadow: 0 0 0 0.5px #FFBE26; }
  .card-books:hover  { border-color: #0B6F5A; box-shadow: 0 0 0 0.5px #0B6F5A; }
  .card-comm:hover,
  .card-energy:hover,
  .card-footwork:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.08); transform: rotate(-1.5deg) translateY(-2px); }

  .about-hero-portrait {
    position: absolute;
    top: 0;
    right: 0;
    width: 300px;
    height: auto;
    z-index: 1;
  }
  .about-hero-text {
    max-width: 600px;
  }

  .hero-title {
    font-size: 30px;
  }
  @media (min-width: 640px) {
    .hero-title { font-size: 36px; }
  }
  @media (min-width: 768px) {
    .hero-title { font-size: 42px; }
  }

  @media (max-width: 900px) {
    .who-iam-grid {
      grid-template-columns: 1fr;
    }
    .who-iam-card {
      flex-direction: row !important;
      align-items: flex-start !important;
      margin-top: 0 !important;
    }
    .who-iam-text {
      text-align: left !important;
    }
    .about-hero-portrait {
      position: static;
      width: 200px;
      margin: 0 auto 0.75rem;
      display: block;
    }
    .about-hero-text {
      max-width: none;
    }
    .about-hero {
      padding-top: 1.5rem !important;
    }
  }
  @media (max-width: 767px) {
    .about-hero { padding-bottom: 32px !important; }
    .card-comm h3,
    .card-energy h3,
    .card-footwork h3 { font-size: 18px; }
  }
  @media (max-width: 500px) {
    .about-hero { padding-bottom: 24px !important; }
    .who-iam-card svg { width: 32px; height: 32px; }
  }
</style>

<Layout title="About — Mingz" showBackLink={true}>
  <section class="pb-12 max-w-[980px] relative">

    <img
      src="/about/about-me-portrait.png"
      alt="Hand-drawn line portrait of Mingz"
      class="about-hero-portrait"
    />

    <!-- Hero -->
    <div class="about-hero pt-12 pb-16">
      <div class="about-hero-text">
        <p class="text-[14px] tracking-wider uppercase text-ink-muted mb-4">Who I Am</p>
        <h1 class="hero-title mb-6">
          <span class="sr-only">Mingz means bright.</span>
          <span aria-hidden="true">Mingz means <span id="about-typewriter-word"></span><span class="typewriter-cursor" aria-hidden="true"></span>.</span>
        </h1>
        <p class="text-sm text-ink-muted leading-[1.8] mb-4">
          The character "明" (Ming) in my name is what I embody. It is made up of the character for "sun" on the left, and "moon" on the right. Put together, it means bright, clear, and intelligent.
        </p>
         <p class="text-sm text-ink-muted leading-[1.8]">
          I don't see myself as just a designer/researcher, but a strategist who is curious, meticulous, and brings the qualities of both the energy from the sun, the steadiness from the moon.
        </p>
      </div>
    </div>

    <!-- Cards row -->
    <div class="who-iam-grid grid grid-cols-3 gap-4 mb-10 items-start">

    <!-- Brain card -->
    <div class="card-brain who-iam-card flex flex-col items-center gap-4 pt-6 pb-6 px-6 border border-border-custom rounded-[10px] transition-all duration-200 ease-out cursor-default mt-6">
      <div class="flex-shrink-0">
