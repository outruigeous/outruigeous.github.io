              <rect width="42" height="42" fill="white" transform="translate(51)"/>
            </clipPath>
          </defs>
        </svg>
      </div>
      <div class="who-iam-text flex flex-col gap-2 text-center">
        <h3 class="text-base font-medium text-ink leading-snug">I'm a designer who is both left and right brained</h3>
        <p class="text-sm text-ink-muted leading-[1.8]">I was a science student all my life till I did a switch to Fine Arts in college. I enjoy creating solutions that are <b>grounded in research and data</b>, while I inject some of my <b>creative flair</b> into the process and design.</p>
      </div>
    </div>

    <!-- Interfaces card -->
    <div class="card-bulb who-iam-card flex flex-col items-center gap-4 pt-6 pb-6 px-6 border border-border-custom rounded-[10px] transition-all duration-200 ease-out cursor-default">
      <div class="flex-shrink-0">
        <svg width="72" height="72" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <clipPath id="clip0_638_1817">
              <rect width="72" height="72" fill="white"/>
            </clipPath>
